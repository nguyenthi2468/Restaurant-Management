// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?
  firstName     String?
  lastName      String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles UserRole[]

  avatarId String?
  avatar   ImageAsset? @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  provider   AuthProvider @default(LOCAL)
  providerId String?      @unique

  ordersCreated  Order[] @relation("OrderCreatedBy")  // Đơn nhân viên tạo
  ordersAsCustomer Order[] @relation("OrderCustomer") // Đơn với tư cách khách
  sessions         AuthSession[]
  verifyTokens     EmailVerifyToken[]
  resetTokens      PasswordResetToken[]
  galleries        ImageGallery[]
  folderGalleries  FolderGallery[]
  bookings         Booking[]
  employeeSchedules EmployeeSchedule[] @relation("EmployeeSchedules")
  timeOffRequests TimeOffRequest[] @relation("EmployeeTimeOffRequests")
  timeOffRequestsReviewed TimeOffRequest[] @relation("TimeOffReviewedBy")
  attendances Attendance[] @relation("EmployeeAttendances")
  contactMessages  ContactMessage[] @relation("ContactMessagesSent")
  contactMessagesHandled ContactMessage[] @relation("ContactHandledBy")
  news             News[]
}
model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  roles       RolePermission[]
  apiPolicies ApiActionPolicy[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@id([roleId, permissionId])
}

model AuthSession {
  id          String       @id @default(cuid())
  userId      String
  jti         String       @unique
  refreshHash String
  provider    AuthProvider @default(LOCAL)

  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  revokedBy String?
  reason    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerifyToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @db.VarChar(64)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model ApiAction {
  id          String            @id @default(cuid())
  key         String            @unique // ví dụ: "hotel.update"
  description String?
  enabled     Boolean           @default(true)
  mode        PolicyMode        @default(ANY)
  policies    ApiActionPolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiActionPolicy {
  action       ApiAction  @relation(fields: [actionId], references: [id])
  actionId     String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@id([actionId, permissionId])
}

model ImageAsset {
  id        String @id @default(cuid())
  // publicId là định danh xoá trên Cloudinary (bắt buộc để delete)
  publicId  String @unique
  url       String
  secureUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Liên kết 1-1 cho avatar user (optional)
  userAvatarOf User[] @relation("UserAvatar")
}

model ImageGallery {
  id        String @id @default(cuid())
  publicId  String @unique
  url       String
  secureUrl String

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  userId    String
  folderId  String
  folder    FolderGallery @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
   // Relations for menu
  menuCategories MenuCategory[] @relation("MenuCategoryImage")
  menuItems MenuItem[] @relation("MenuItemImage")
  news News[]
}

model FolderGallery {
  id         String         @id @default(cuid())
  folderName String         @unique
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleries  ImageGallery[]
}

// ==================== TABLE MODELS ====================
model Floor {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  tables    Table[]
}
model Table {
  id        String      @id @default(cuid())
  name      String      @unique
  floorId   String
  floor     Floor       @relation(fields: [floorId], references: [id])
  area      TableArea   @default(NORMAL)
  seats  Int
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orderTables OrderTable[] // Many-to-many relation with Order
  bookings  BookingTable[] // Added for BookingTable relation

  @@index([status])
}

enum TableArea {
  NORMAL
  VIP
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// ==================== ORDER MODELS ====================

model Order {
  id        Int         @id @default(autoincrement())
  status    OrderStatus @default(SERVED)
  total     Decimal     @db.Decimal(12, 3) @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  note    String?
  // 👇 Nhân viên tạo order (bắt buộc)
  createdById String
  createdBy   User   @relation("OrderCreatedBy", fields: [createdById], references: [id])

  // 👇 Khách đã có tài khoản (optional)
  customerId  String?
  customer    User?  @relation("OrderCustomer", fields: [customerId], references: [id])

  // 👇 Khách vãng lai (optional, dùng khi customer = null)
  customerName  String @default("Khách lẻ")
  customerPhone String?

  depositAmount     Decimal     @db.Decimal(12, 3) @default(0)
  items     OrderItem[]
  payments  Payment[]
  orderTables OrderTable[] // Many-to-many relation with Table
  kitchenTickets KitchenTicket[]

  @@index([status])
  @@index([createdById])
  @@index([customerId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Decimal  @db.Decimal(12, 3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  note       String?

  @@index([orderId])
  @@index([menuItemId])
}

enum OrderStatus {
  PENDING
  SERVED
  COMPLETED
  CANCELLED
}

// Junction table for many-to-many relationship between Order and Table
model OrderTable {
  id        String   @id @default(cuid())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id])
  createdAt DateTime @default(now())

  @@unique([orderId, tableId])
  @@index([tableId])
}

// ==================== MENU MODELS ====================

model MenuCategory {
  id            String   @id @default(cuid())
  name          String
  description   String?
  imageId       String?
  image         ImageGallery? @relation("MenuCategoryImage", fields: [imageId], references: [id], onDelete: SetNull)
  // For ordering categories in the menu
  position      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relation to menu items
  menuItems     MenuItem[]

  @@index([isActive])
  @@index([position])
}

model MenuItem {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(12, 3) // Price in currency units
  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageId       String?
  image         ImageGallery? @relation("MenuItemImage", fields: [imageId], references: [id], onDelete: SetNull)
  // For ordering items within category
  position      Int      @default(0)
  isAvailable   Boolean  @default(true)
  // Dietary information
  isVegetarian  Boolean  @default(false)
  isVegan       Boolean  @default(false)
  isGlutenFree  Boolean  @default(false)
  isSpicy       Boolean  @default(false)
  // Preparation time in minutes
  preparationTime Int?   // Null if standard time
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  isFeature      Boolean @default(false)
  // Relations for ingredients and options
  ingredients   MenuItemIngredient[]
  orderItems    OrderItem[]
  bookingItems  BookingMenuItem[] // Added for BookingMenuItem relation
  kitchenTicketItems KitchenTicketItem[]
  @@index([categoryId])
  @@index([isAvailable])
  @@index([position])
}

model MenuItemIngredient {
  id            String   @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientName String
  quantity      Decimal  @db.Decimal(8, 3) // Quantity needed per serving
  unit          String   // e.g., "g", "ml", "pcs", "oz"
  isAllergen    Boolean  @default(false) // Mark if this ingredient is a common allergen
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([menuItemId])
  @@index([isAllergen])
}

// ==================== ENUM ====================

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PolicyMode {
  ANY // chỉ cần 1 quyền trong danh sách
  ALL // cần đủ toàn bộ quyền
}

enum ImageKind {
  AVATAR // avatar user
  COVER // ảnh bìa/cover
  GALLERY // ảnh trong bộ sưu tập
  DOC // tài liệu/biên lai nếu cần
}

// ==================== BOOKING MODELS ====================

model Booking {
  id               String        @id @default(cuid())
  customerId       String?
  customer         User?         @relation(fields: [customerId], references: [id])
  customerName     String
  customerPhone    String
  customerEmail    String
  bookingTime      DateTime
  endTime          DateTime
  numberOfGuests   Int
  numberOfChildren Int           @default(0)
  note             String?
  depositAmount    Decimal       @default(0) @db.Decimal(12, 3)
  depositStatus    DepositStatus @default(PENDING)
  status           BookingStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  bookingTables BookingTable[]
  preOrderItems BookingMenuItem[]
  payments      Payment[]

  @@index([bookingTime, endTime])
}

model BookingTable {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id])

  @@unique([bookingId, tableId])
  @@index([tableId])
}

model BookingMenuItem {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Decimal  @db.Decimal(12, 3)

  @@unique([bookingId, menuItemId])
  @@index([menuItemId])
}

model Payment {
  id        String @id @default(cuid())
  bookingId String?
  booking   Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  orderId Int?
  order   Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactionCode String
  amount    Decimal  @db.Decimal(12, 3)
  status    PaymentStatus @default(PENDING)
  method          PaymentMethod @default(CASH)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum PaymentMethod {
  CASH
  VNPAY
}
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum DepositStatus {
  PENDING
  PAID
  REFUNDED
  WAIVED
}

// ==================== KITCHEN MODE MODELS ====================
// Phiếu gửi bếp (mỗi lần gọi món tạo 1 ticket)
model KitchenTicket {
  id          String              @id @default(cuid())
  orderId     Int
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      KitchenTicketStatus @default(PENDING)
  priority    Int                 @default(0)      // 0=normal, 1=rush
  note        String?
  sentAt      DateTime            @default(now())  // Lúc gửi xuống bếp
  acceptedAt  DateTime?           // Bếp xác nhận nhận
  completedAt DateTime?           // Bếp làm xong
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items       KitchenTicketItem[]

  @@index([status])
  @@index([orderId])
}

model KitchenTicketItem {
  id              String        @id @default(cuid())
  ticketId        String
  ticket          KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  completedQty    Int     @default(0)   
  servedQty       Int     @default(0)
  quantity        Int
  status          KitchenItemStatus @default(PENDING)
  note            String?
  completedAt     DateTime?

  @@index([ticketId])
  @@index([menuItemId])
}

enum KitchenTicketStatus {
  PENDING     // Chờ bếp xác nhận
  ACCEPTED    // Bếp đã nhận
  CANCELLED
}

enum KitchenItemStatus {
  PENDING
  COOKING
  READY
  SERVED
  CANCELLED
}

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  FULL_DAY
}

enum ScheduleStatus {
  SCHEDULED
  COMPLETED
  ABSENT
  LATE
  CANCELLED
}

enum TimeOffRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TimeOffType {
  SICK_LEAVE
  VACATION
  PERSONAL
  UNPAID
}

enum AttendanceStatus {
  ON_TIME
  LATE
  ABSENT
  EXCUSED
}

// ==================== EMPLOYEE SCHEDULE MANAGEMENT ====================

model Shift {
  id          String    @id @default(cuid())
  name        String
  type        ShiftType
  startTime   String
  endTime     String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  schedules EmployeeSchedule[]

  @@index([isActive])
}

model EmployeeSchedule {
  id         String         @id @default(cuid())
  employeeId String
  employee   User           @relation("EmployeeSchedules", fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    String
  shift      Shift          @relation(fields: [shiftId], references: [id])
  date       DateTime
  status     ScheduleStatus @default(SCHEDULED)
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([employeeId, date, shiftId])
  @@index([employeeId])
  @@index([shiftId])
  @@index([date])
  @@index([status])
}

model TimeOffRequest {
  id           String               @id @default(cuid())
  employeeId   String
  employee     User                 @relation("EmployeeTimeOffRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  type         TimeOffType
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       TimeOffRequestStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?                @relation("TimeOffReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
}

model Attendance {
  id           String           @id @default(cuid())
  employeeId   String
  employee     User             @relation("EmployeeAttendances", fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  clockIn      DateTime?
  clockOut     DateTime?
  status       AttendanceStatus @default(ON_TIME)
  workHours    Decimal?         @db.Decimal(5, 2)
  overtimeHours Decimal?        @db.Decimal(5, 2)
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}
enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model ContactMessage {
  id String @id @default(cuid())

  // Người gửi (public)
  name    String
  email   String?
  phone   String?
  subject String?
  message String

  // Metadata chống spam / trace
  ip        String?
  userAgent String?

  status ContactStatus @default(NEW)

  // (Tuỳ chọn) nếu user đã đăng nhập và bạn muốn lưu
  userId String?
  user   User?   @relation("ContactMessagesSent", fields: [userId], references: [id], onDelete: SetNull)

  // Admin xử lý
  handledById String?
  handledBy   User?   @relation("ContactHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  // Ghi chú nội bộ
  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model News {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  summary     String?
  content     String? // nếu bạn lưu HTML/markdown
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?

  // audit
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  imageId String?
  image ImageGallery? @relation(fields: [imageId], references: [id], onDelete: SetNull)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([createdAt])
}