// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?
  firstName     String?
  lastName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles UserRole[]

  avatarId String?
  avatar   ImageAsset? @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  provider   AuthProvider @default(LOCAL)
  providerId String?      @unique

  sessions         AuthSession[]
  verifyTokens     EmailVerifyToken[]
  resetTokens      PasswordResetToken[]
  galleries        ImageGallery[]
  folderGalleries  FolderGallery[]

}
model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  roles       RolePermission[]
  apiPolicies ApiActionPolicy[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@id([roleId, permissionId])
}

model AuthSession {
  id          String       @id @default(cuid())
  userId      String
  jti         String       @unique
  refreshHash String
  provider    AuthProvider @default(LOCAL)

  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  revokedBy String?
  reason    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerifyToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @db.VarChar(64)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model ApiAction {
  id          String            @id @default(cuid())
  key         String            @unique // ví dụ: "hotel.update"
  description String?
  enabled     Boolean           @default(true)
  mode        PolicyMode        @default(ANY)
  policies    ApiActionPolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiActionPolicy {
  action       ApiAction  @relation(fields: [actionId], references: [id])
  actionId     String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@id([actionId, permissionId])
}

model ImageAsset {
  id        String @id @default(cuid())
  // publicId là định danh xoá trên Cloudinary (bắt buộc để delete)
  publicId  String @unique
  url       String
  secureUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Liên kết 1-1 cho avatar user (optional)
  userAvatarOf User[] @relation("UserAvatar")
}

model ImageGallery {
  id        String @id @default(cuid())
  publicId  String @unique
  url       String
  secureUrl String

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  userId    String
  folderId  String
  folder    FolderGallery @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
   // Relations for menu
  menuCategories MenuCategory[] @relation("MenuCategoryImage")
  menuItems MenuItem[] @relation("MenuItemImage")
}

model FolderGallery {
  id         String         @id @default(cuid())
  folderName String         @unique
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleries  ImageGallery[]
}

// ==================== TABLE MODELS ====================

model Table {
  id        String      @id @default(cuid())
  name      String      @unique
  floor     String      
  area      TableArea   @default(NORMAL)
  seats  Int
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders    Order[]

  @@index([status])
}

enum TableArea {
  NORMAL
  VIP
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// ==================== ORDER MODELS ====================

model Order {
  id        String      @id @default(cuid())
  tableId   String
  table     Table       @relation(fields: [tableId], references: [id])
  status    OrderStatus @default(PENDING)
  total     Decimal     @db.Decimal(12, 3) @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  note    String?
  customerName    String?
  customerPhone    String?
  items     OrderItem[]

  @@index([tableId])
  @@index([status])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Decimal  @db.Decimal(12, 3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId])
  @@index([menuItemId])
}

enum OrderStatus {
  PENDING
  SERVED
  COMPLETED
  CANCELLED
}

// ==================== MENU MODELS ====================

model MenuCategory {
  id            String   @id @default(cuid())
  name          String
  description   String?
  imageId       String?
  image         ImageGallery? @relation("MenuCategoryImage", fields: [imageId], references: [id], onDelete: SetNull)
  // For ordering categories in the menu
  position      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relation to menu items
  menuItems     MenuItem[]

  @@index([isActive])
  @@index([position])
}

model MenuItem {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(12, 3) // Price in currency units
  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageId       String?
  image         ImageGallery? @relation("MenuItemImage", fields: [imageId], references: [id], onDelete: SetNull)
  // For ordering items within category
  position      Int      @default(0)
  isAvailable   Boolean  @default(true)
  // Dietary information
  isVegetarian  Boolean  @default(false)
  isVegan       Boolean  @default(false)
  isGlutenFree  Boolean  @default(false)
  isSpicy       Boolean  @default(false)
  // Preparation time in minutes
  preparationTime Int?   // Null if standard time
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations for ingredients and options
  ingredients   MenuItemIngredient[]
  options       MenuItemOption[] @relation("MenuItemOptions")
  orderItems    OrderItem[]

  @@index([categoryId])
  @@index([isAvailable])
  @@index([position])
}

model MenuItemIngredient {
  id            String   @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientName String
  quantity      Decimal  @db.Decimal(8, 3) // Quantity needed per serving
  unit          String   // e.g., "g", "ml", "pcs", "oz"
  isAllergen    Boolean  @default(false) // Mark if this ingredient is a common allergen
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([menuItemId])
  @@index([isAllergen])
}

model MenuItemOption {
  id            String   @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem @relation("MenuItemOptions", fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String   // e.g., "Extra cheese", "Spice level"
  description   String?
  // For grouping options (e.g., "Size", "Toppings", "Cooking level")
  group         String?
  isRequired    Boolean  @default(false)
  // For ordering options
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relation to option values
  values        MenuItemOptionValue[] @relation("MenuItemOptionValues")

  @@index([menuItemId])
  @@index([position])
}

model MenuItemOptionValue {
  id            String   @id @default(cuid())
  optionId      String
  option        MenuItemOption @relation("MenuItemOptionValues", fields: [optionId], references: [id], onDelete: Cascade)
  name          String   // e.g., "Small", "Medium", "Large" or "Mild", "Medium", "Hot"
  description   String?
  // Additional price for this option value
  priceAdjustment Decimal @db.Decimal(12, 3) @default(0) // Can be positive or negative
  // For ordering values within an option
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([optionId])
  @@index([position])
}

// ==================== ENUM ====================

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PolicyMode {
  ANY // chỉ cần 1 quyền trong danh sách
  ALL // cần đủ toàn bộ quyền
}

enum ImageKind {
  AVATAR // avatar user
  COVER // ảnh bìa/cover
  GALLERY // ảnh trong bộ sưu tập
  DOC // tài liệu/biên lai nếu cần
}